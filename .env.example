# ─────────────────────────────────────────────────────────────────────────────
# OpenClaw / Dwight — Environment Variables
# Copy this file to ~/.openclaw/.env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram ──────────────────────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_TOKEN=

# ── OpenRouter (cloud LLM fallback) ──────────────────────────────────────────
# API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ── Google Ads Keyword Planner API (free keyword expansion) ──────────────────
# Step-by-step setup: run python3 scripts/google_ads_setup.py
#
# 1. Developer token — from https://ads.google.com/aw/apicenter
#    Requires a Google Ads Manager (MCC) account. Basic Access is sufficient.
GOOGLE_ADS_DEVELOPER_TOKEN=

# 2. OAuth2 Client ID + Secret — from https://console.cloud.google.com/apis/credentials
#    Create a Desktop app OAuth2 client. Enable "Google Ads API" in API Library.
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=

# 3. Refresh token — generated once by scripts/google_ads_setup.py
GOOGLE_ADS_REFRESH_TOKEN=

# 4. Customer ID — your Google Ads account ID (digits only, no dashes)
#    Must have a payment method on file (no spend required, just billing configured).
GOOGLE_ADS_CUSTOMER_ID=

# 5. Login Customer ID — your MCC manager account ID (if using sub-accounts)
#    Leave blank if you only have a single account (not an MCC).
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# ── DataForSEO (paid keyword validation) ─────────────────────────────────────
# Account credentials from https://app.dataforseo.com/api-access
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Maximum DataForSEO keyword lookups per day.
# Each request covers up to 1000 keywords.
# At $0.05/request (standard queue), 75 requests = $3.75/day max.
DATAFORSEO_DAILY_BUDGET=75

# ── Brave Search (SERP vetting fallback) ─────────────────────────────────────
# Optional — used as fallback if DuckDuckGo is unavailable.
# Get a free key at https://api.search.brave.com/
BRAVE_API_KEY=
